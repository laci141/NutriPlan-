<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Az alkalmazás teljesen offline működik, internet engedély nem szükséges. -->

    <!-- Lépésszámláláshoz (a kezdőlap lépés-kártyája); a szenzor opcionális. -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <uses-feature
        android:name="android.hardware.sensor.stepcounter"
        android:required="false" />

    <application
        android:name=".NutriPlanApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NutriPlan">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="uiMode|locale|layoutDirection"
            android:theme="@style/Theme.NutriPlan">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
